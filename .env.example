# Deuce — Provider Configuration
#
# Two ways to add providers:
#
# ═══════════════════════════════════════════════════════════
# OPTION 1: Legacy env vars (quick start)
# Just add the key. Deuce auto-detects it.
# ═══════════════════════════════════════════════════════════

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...

# ═══════════════════════════════════════════════════════════
# OPTION 2: Dynamic providers (add anything)
# Use AI_PROVIDER_# to add any provider — native or custom.
# ═══════════════════════════════════════════════════════════

# --- Native provider (Nexus knows how to connect) ---
# AI_PROVIDER_1=anthropic
# AI_PROVIDER_1_KEY=sk-ant-...
#
# AI_PROVIDER_2=openai
# AI_PROVIDER_2_KEY=sk-...
#
# --- OpenAI-compatible provider (any API that speaks OpenAI) ---
# AI_PROVIDER_3=openai-compatible
# AI_PROVIDER_3_KEY=your-minimax-key
# AI_PROVIDER_3_NAME=MiniMax M2.7
# AI_PROVIDER_3_BASE_URL=https://api.minimax.io/v1
# AI_PROVIDER_3_MODEL=MiniMax-M2.7
#
# AI_PROVIDER_4=openai-compatible
# AI_PROVIDER_4_KEY=your-together-key
# AI_PROVIDER_4_NAME=Together AI
# AI_PROVIDER_4_BASE_URL=https://api.together.xyz/v1
# AI_PROVIDER_4_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# AI_PROVIDER_5=openai-compatible
# AI_PROVIDER_5_KEY=your-groq-key
# AI_PROVIDER_5_NAME=Groq
# AI_PROVIDER_5_BASE_URL=https://api.groq.com/openai/v1
# AI_PROVIDER_5_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════
# SETTINGS
# ═══════════════════════════════════════════════════════════

# Default provider (must match a provider id above, or: anthropic, openai, etc.)
# NEXUS_DEFAULT_PROVIDER=anthropic

# Ollama works automatically if running locally — no key needed.
# OLLAMA_BASE_URL=http://localhost:11434

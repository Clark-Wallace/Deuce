# Deuce — Provider Configuration
#
# Two ways to add providers. Both can be used together.
#
# ═══════════════════════════════════════════════════════════
# OPTION 1: Legacy env vars (simplest — just add the key)
# ═══════════════════════════════════════════════════════════
#
# Deuce auto-detects these and uses the default model for each.
#
# ANTHROPIC_API_KEY=sk-ant-...          → claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-...                 → gpt-4o
# GOOGLE_API_KEY=...                    → gemini-2.0-flash
# DEEPSEEK_API_KEY=...                  → deepseek-chat
# XAI_API_KEY=...                       → grok-3

# ═══════════════════════════════════════════════════════════
# OPTION 2: Dynamic AI_PROVIDER_# (full control)
# Add any provider. Set any model. No code changes.
# ═══════════════════════════════════════════════════════════
#
# NATIVE PROVIDERS (Nexus has a built-in connector)
# Use _MODEL to override the default model.
#
# AI_PROVIDER_1=anthropic
# AI_PROVIDER_1_KEY=sk-ant-...
# AI_PROVIDER_1_MODEL=claude-sonnet-4-20250514
#
# AI_PROVIDER_2=openai
# AI_PROVIDER_2_KEY=sk-...
# AI_PROVIDER_2_MODEL=gpt-4o
#
# AI_PROVIDER_3=deepseek
# AI_PROVIDER_3_KEY=sk-...
# AI_PROVIDER_3_MODEL=deepseek-reasoner

# OPENAI-COMPATIBLE PROVIDERS (any API that speaks OpenAI format)
# Requires: _NAME, _BASE_URL, _KEY. Model optional but recommended.
#
# AI_PROVIDER_4=openai-compatible
# AI_PROVIDER_4_KEY=your-minimax-key
# AI_PROVIDER_4_NAME=MiniMax M2.7
# AI_PROVIDER_4_BASE_URL=https://api.minimax.io/v1
# AI_PROVIDER_4_MODEL=MiniMax-M2.7
#
# AI_PROVIDER_5=openai-compatible
# AI_PROVIDER_5_KEY=your-together-key
# AI_PROVIDER_5_NAME=Together AI
# AI_PROVIDER_5_BASE_URL=https://api.together.xyz/v1
# AI_PROVIDER_5_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# AI_PROVIDER_6=openai-compatible
# AI_PROVIDER_6_KEY=your-groq-key
# AI_PROVIDER_6_NAME=Groq
# AI_PROVIDER_6_BASE_URL=https://api.groq.com/openai/v1
# AI_PROVIDER_6_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════
# SETTINGS
# ═══════════════════════════════════════════════════════════

# Default provider (must match a provider id: anthropic, openai, custom_4, etc.)
# NEXUS_DEFAULT_PROVIDER=anthropic

# Ollama — runs automatically if installed. No key needed.
# OLLAMA_BASE_URL=http://localhost:11434

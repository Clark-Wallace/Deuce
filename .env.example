# Deuce — API Keys
# Add your keys for the providers you want to use.
# At least one is required. Deuce auto-detects available providers.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...

# MiniMax — https://platform.minimax.io/
# OpenAI-compatible API. Default model: MiniMax-M2.7
# MINIMAX_API_KEY=...

# Optional: set a default provider (otherwise uses first available)
# NEXUS_DEFAULT_PROVIDER=anthropic

# Ollama works automatically if running locally — no key needed.
# OLLAMA_BASE_URL=http://localhost:11434
